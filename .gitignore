# macOS
.DS_Store

# Slide content — release one session at a time.
# To publish a session, add a `!` line for its .md and .pdf.
slides/decks/*
!slides/decks/.gitkeep
!slides/decks/theme.css
!slides/decks/session1.md
!slides/decks/session1.pdf
!slides/decks/session2.md
!slides/decks/session2.pdf
slides/assets/*
!slides/assets/.gitkeep
!slides/assets/*.svg

